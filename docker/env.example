# Docker Compose 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置
# 命令: cp env.example .env

# MySQL 配置
MYSQL_ROOT_PASSWORD=aihub123456
MYSQL_DATABASE=aihub
MYSQL_USER=aihub
MYSQL_PASSWORD=aihub123456
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=aihub123456
REDIS_PORT=6379

# RAG 服务配置

# Qdrant 向量数据库配置
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Meilisearch 全文搜索引擎配置
MEILISEARCH_PORT=7700
MEILI_MASTER_KEY=devKey123

# Embedding 配置（本地开源模型，阶段1使用 BGE-small）
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_MODEL=bge-small-zh-v1.5

# 前端服务配置
BACKEND_PORT=8080
FRONTEND_PORT=3000

# JWT 配置（生产环境必须修改）
JWT_SECRET=aihub-secret-key-change-in-production-environment-minimum-32-characters

# 前端 API 地址（Docker 内部使用服务名，外部访问使用 localhost）
VITE_API_BASE_URL=http://localhost:8080

# 服务端口配置
BACKEND_PORT=8080
FRONTEND_PORT=3000

# JWT 配置（生产环境必须修改）
JWT_SECRET=aihub-secret-key-change-in-production-environment-minimum-32-characters

# 前端 API 地址（Docker 内部使用服务名，外部访问使用 localhost）
VITE_API_BASE_URL=http://localhost:8080
