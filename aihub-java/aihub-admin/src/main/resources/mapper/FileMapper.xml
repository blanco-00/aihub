<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aihub.admin.mapper.FileMapper">

    <!-- 文件列表结果映射 -->
    <resultMap id="FileListResultMap" type="com.aihub.admin.dto.response.FileListResponse">
        <id property="id" column="id"/>
        <result property="url" column="file_url"/>
        <result property="filename" column="filename"/>
        <result property="size" column="file_size"/>
        <result property="contentType" column="content_type"/>
        <result property="category" column="category"/>
        <result property="uploadTime" column="created_at"/>
        <result property="path" column="file_path"/>
        <result property="uploadUsername" column="upload_username"/>
        <result property="referenceCount" column="reference_count"/>
    </resultMap>

    <!-- 查询文件列表 -->
    <select id="selectFileList" resultMap="FileListResultMap">
        SELECT 
            id,
            filename,
            file_url,
            file_size,
            content_type,
            category,
            upload_username,
            reference_count,
            file_path,
            created_at
        FROM file
        WHERE is_deleted = 0
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        <if test="keyword != null and keyword != ''">
            AND filename LIKE CONCAT('%', #{keyword}, '%')
        </if>
        ORDER BY created_at DESC
        <if test="offset != null and limit != null">
            LIMIT #{offset}, #{limit}
        </if>
    </select>

    <!-- 统计文件总数 -->
    <select id="countFileList" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM file
        WHERE is_deleted = 0
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        <if test="keyword != null and keyword != ''">
            AND filename LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </select>

</mapper>
